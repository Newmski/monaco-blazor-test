@page "/"
@inject MonacoBlazorWasmSample.Client.Services.IScriptValidationService ValidationService

<PageTitle>Monaco + Blazor WASM</PageTitle>

<h1>Script editor</h1>
<p class="intro">
    This sample shows one way to host Monaco inside Blazor WASM and wire it to a validation flow.
</p>

<div class="grid">
    <section class="card form-card">
        <div class="field-row">
            <label for="script-name">Script name</label>
            <input id="script-name" @bind="_scriptName" />
        </div>

        <div class="field-row">
            <label for="seam">Seam</label>
            <select id="seam" @bind="_selectedSeam" @bind:after="LoadTemplateAsync">
                @foreach (var seam in SeamTemplates.All)
                {
                    <option value="@seam.Key">@seam.Name</option>
                }
            </select>
        </div>

        <div class="button-row">
            <button class="secondary" @onclick="LoadTemplate">Load template</button>
            <button @onclick="ValidateAsync">Validate</button>
        </div>
    </section>

    <section class="card help-card">
        <h2>Available globals</h2>
        <ul>
            <li><code>Employee</code></li>
            <li><code>ExistingEmployee</code></li>
            <li><code>Context</code></li>
        </ul>

        <h2>Expected result</h2>
        <p>Return <code>BeforeEmployeeSavedResult</code>.</p>
    </section>
</div>

<section class="card editor-card">
    <MonacoEditor Value="@_code" ValueChanged="OnCodeChanged" Height="480px" />
</section>

<section class="card diagnostics-card">
    <div class="diagnostics-header">
        <h2>Diagnostics</h2>
        @if (_diagnostics.Count == 0)
        {
            <span class="badge ok">No issues</span>
        }
    </div>

    @if (_diagnostics.Count == 0)
    {
        <p>No diagnostics to show.</p>
    }
    else
    {
        <table class="diagnostics-table">
            <thead>
                <tr>
                    <th>Severity</th>
                    <th>Line</th>
                    <th>Column</th>
                    <th>Message</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var diagnostic in _diagnostics)
                {
                    <tr>
                        <td>@diagnostic.Severity</td>
                        <td>@diagnostic.Line</td>
                        <td>@diagnostic.Column</td>
                        <td>@diagnostic.Message</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private string _scriptName = "Validate employee before save";
    private string _selectedSeam = SeamTemplates.BeforeEmployeeSaved.Key;
    private string _code = SeamTemplates.BeforeEmployeeSaved.Template;
    private List<ScriptDiagnosticModel> _diagnostics = new();

    private Task OnCodeChanged(string value)
    {
        _code = value;
        return Task.CompletedTask;
    }

    private Task LoadTemplateAsync()
    {
        LoadTemplate();
        return Task.CompletedTask;
    }

    private void LoadTemplate()
    {
        _code = SeamTemplates.All.First(x => x.Key == _selectedSeam).Template;
        _diagnostics.Clear();
    }

    private async Task ValidateAsync()
    {
        var result = await ValidationService.ValidateAsync(_selectedSeam, _code);
        _diagnostics = result.Diagnostics.ToList();
    }
}
