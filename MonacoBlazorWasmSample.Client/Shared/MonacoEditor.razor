@implements IAsyncDisposable
@inject IJSRuntime JS

<div id="@_editorElementId" class="monaco-host" style="height:@Height"></div>

@code {
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Height { get; set; } = "420px";
    [Parameter] public string Language { get; set; } = "csharp";
    [Parameter] public string Theme { get; set; } = "vs";

    private readonly string _editorElementId = $"editor_{Guid.NewGuid():N}";
    private IJSObjectReference? _module;
    private DotNetObjectReference<MonacoEditor>? _dotNetRef;
    private bool _created;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/monacoInterop.js");
        _dotNetRef = DotNetObjectReference.Create(this);

        await _module.InvokeVoidAsync("createMonacoEditor", _editorElementId, new
        {
            value = Value,
            language = Language,
            theme = Theme,
            dotNetRef = _dotNetRef
        });

        _created = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_created && _module is not null)
        {
            var currentValue = await _module.InvokeAsync<string>("getValue", _editorElementId);
            if (!string.Equals(currentValue, Value, StringComparison.Ordinal))
            {
                await _module.InvokeVoidAsync("setValue", _editorElementId, Value);
            }
        }
    }

    [JSInvokable]
    public async Task NotifyValueChanged(string value)
    {
        Value = value;
        await ValueChanged.InvokeAsync(value);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("disposeEditor", _editorElementId);
                await _module.DisposeAsync();
            }
            catch
            {
            }
        }

        _dotNetRef?.Dispose();
    }
}
